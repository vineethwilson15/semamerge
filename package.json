{
  "name": "semamerge",
  "version": "0.1.2",
  "mcpName": "io.github.vineethwilson15/semamerge",
  "description": "MCP server that detects semantic (non-textual) merge conflicts between Git branches using AST-level analysis",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "semamerge": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "node --experimental-vm-modules node_modules/.bin/vitest run",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/vitest"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "semantic-merge",
    "git",
    "ast",
    "conflict-detection",
    "tree-sitter",
    "merge-conflicts"
  ],
  "author": "vineethwilson15",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vineethwilson15/semamerge.git"
  },
  "homepage": "https://github.com/vineethwilson15/semamerge#readme",
  "bugs": {
    "url": "https://github.com/vineethwilson15/semamerge/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "simple-git": "^3.27.0",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "^0.24.7",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
